# Variables de entorno para Booki Svelte
VITE_RAPIDAPI_KEY=tu_clave_api_aqui
VITE_RAPIDAPI_HOST=booking-com.p.rapidapi.com
VITE_JWT_SECRET=tu_jwt_secret_aqui
VITE_API_INTERNAL_URL=tu_api_internal_url_aqui
VITE_API_INTERNAL_KEY=tu_api_internal_key_aqui
VITE_PSE_URL=http://127.0.0.1:5501

# Descuento (puede usar cualquiera de las dos opciones):
# Opción 1: Como porcentaje (ejemplo: 20 = 20%)
VITE_DISCOUNT_PERCENTAGE=20
# Opción 2: Como proporción (ejemplo: 0.20 = 20%)
# VITE_PRICE_DISCOUNT=0.20